RewriteEngine On

# Public showcase: do not redirect local installations to the former production domain.
# Deny direct access to configuration, logs, dumps, and private key formats.
<FilesMatch "(^\.env|\.ini$|\.log$|\.sql$|\.sqlite$|\.db$|\.pem$|\.key$|\.p12$)">
    Require all denied
</FilesMatch>

